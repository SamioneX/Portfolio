# Cloudflare API token — scripts/deploy.sh seeds this into AWS Secrets Manager.
# CDK Lambda custom resources read it from there at runtime.
# Never baked into CloudFormation templates or Lambda environment variables.
#
# Create a token at https://dash.cloudflare.com/profile/api-tokens with:
#   Zone / DNS / Edit   permission for the sokech.com zone
CLOUDFLARE_TOKEN=YOUR_CLOUDFLARE_TOKEN_HERE

# GitHub repo in "org/repo" format — scopes the OIDC deploy role so only
# this repo's Actions workflows can assume it.
GITHUB_REPO=SamioneX/portfolio